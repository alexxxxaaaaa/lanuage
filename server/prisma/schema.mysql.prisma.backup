generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  username          String             @unique
  passwordHash      String
  createdAt         DateTime           @default(now())
  folders           Folder[]
  notes             Note[]
  expressionFolders ExpressionFolder[]
  aiUsageLogs       AiUsageLog[]
}

model Folder {
  id       String @id @default(uuid())
  name     String
  language String
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  words    Word[]

  @@index([userId])
}

model Word {
  id           String   @id @default(uuid())
  word         String
  reading      String
  meaning      String   @db.Text
  example      String   @db.LongText
  note         String   @db.Text
  partOfSpeech String   @default("")
  language     String
  folderId     String
  sourceNoteId String?
  folder       Folder   @relation(fields: [folderId], references: [id])
  sourceNote   Note?    @relation(fields: [sourceNoteId], references: [id])
  review       Review?
  createdAt    DateTime @default(now())

  @@unique([folderId, word])
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.LongText
  course    String   @default("")
  lesson    String   @default("")
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  words     Word[]

  @@index([userId])
}

model Review {
  id             String   @id @default(uuid())
  wordId         String   @unique
  word           Word     @relation(fields: [wordId], references: [id])
  interval       Int      @default(1)
  repetition     Int      @default(0)
  easeFactor     Float    @default(2.5)
  difficultyScore Int     @default(0)
  lastRating     String   @default("")
  recentRatings  String   @default("")
  firstLearnedAt DateTime?
  nextReviewDate DateTime
  lastReviewedAt DateTime?
}

model AiUsageLog {
  id               String   @id @default(uuid())
  word             String
  language         String
  model            String
  feature          String   @default("other")
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  createdAt        DateTime @default(now())
  userId           String
  user             User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Expression {
  id         String           @id @default(uuid())
  zhText     String           @db.Text
  enCasual   String           @db.Text
  jpCasual   String           @db.Text
  sceneTag   String           @default("")
  note       String           @db.Text
  isMastered Boolean          @default(false)
  folderId   String
  folder     ExpressionFolder @relation(fields: [folderId], references: [id])
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model ExpressionFolder {
  id          String       @id @default(uuid())
  name        String
  language    String
  expressions Expression[]
  createdAt   DateTime     @default(now())
  userId      String
  user        User         @relation(fields: [userId], references: [id])

  @@unique([name, language, userId])
  @@index([userId])
}
