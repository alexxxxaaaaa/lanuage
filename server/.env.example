PORT=3000

# Local development uses SQLite
DATABASE_URL="file:./dev.db"

# Required for auth — generate one with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string"

# Required for AI features
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4.1-mini"

# Optional: daily AI token cap per user (default 50000)
# DAILY_AI_TOKEN_BUDGET=50000

# Optional: only used if you run `npm run migrate:mysql-to-sqlite` to import legacy data
# LEGACY_MYSQL_URL="mysql://user:pass@localhost:3306/word_app"
